# Database (defaults to SQLite at data/leads.db)
# DATABASE_URL=sqlite:///data/leads.db

# Hunter.io API key for email enrichment (optional, now wired into /enrich-hunter endpoint)
# HUNTER_API_KEY=

# Google Places API key (get from https://console.cloud.google.com)
GOOGLE_PLACES_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
